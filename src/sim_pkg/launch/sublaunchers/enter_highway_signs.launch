<?xml version="1.0" encoding="UTF-8"?>

<launch>

  <!-- ENTER HIGHWAY SIGNS -->
  <node
      name  = "EHIGH_1"
      pkg   = "gazebo_ros"
      exec = "spawn_entity.py"
      args  = "-file $(find-pkg-share models_pkg)/enter_highway_sign/model.sdf -entity EHIGH_1 -x 4.477593 -y -2.357600 -z 0.078998 -R 0 -P 0 -Y 3.120884"/>

  <node
      name  = "EHIGH_2"
      pkg   = "gazebo_ros"
      exec = "spawn_entity.py"
      args  = "-file $(find-pkg-share models_pkg)/enter_highway_sign/model.sdf -entity EHIGH_2 -x 10.374900 -y -2.916130 -z 0.078998 -R 0 -P 0 -Y 0"/>

</launch>
